# Jira Configuration
# Copy this file to .env and fill in your actual values
# .env is NOT committed to version control (see .gitignore)

# Jira instance base URL (without trailing slash)
# Example: https://company.atlassian.net
JIRA_BASE_URL=https://your-instance.atlassian.net

# Email address of your Jira account
# Example: yourname@company.com
JIRA_EMAIL=your-email@company.com

# Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
# Example: ZXhhbXBlOnRva2Vu
JIRA_API_TOKEN=your-api-token-here

# Scrum board ID (find in the board URL: /software/c/projects/PROJ/boards/123)
# Example: 123
JIRA_BOARD_ID=123
